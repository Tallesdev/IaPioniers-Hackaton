@model IaPioniers.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Visão Geral";
}

<div class="dashboard-container">
    <aside class="sidebar">
        <h2>ATENA</h2>
        <nav>
            <a href="#">Início</a>
            <a href="#">Alunos</a>
            <a href="#">Turmas</a>
            <a href="#">Atividades</a>
            <a href="#">Configurações</a>
        </nav>
        <a href="#" class="logout">Sair</a>
    </aside>

    <main class="main-content">
        <header class="top-header">
            <h1>Visão Geral</h1>
            <div class="user-info">Prof. @Model.ProfessorNome</div>
            @if (Model.CurrentModuleInfo != null && !string.IsNullOrEmpty(Model.CurrentModuleInfo.Display_name))
            {
                <div class="module-info">@Model.CurrentModuleInfo.Display_name</div>
            }
        </header>

        <section class="cards">
            @* CARD 1: Atividades - Corrigido para TotalActivities *@
            <div class="card blue">
                <h2>@Model.TotalActivities</h2>
                <p>Atividades</p>
                <button>Ver Atividades</button>
            </div>

            @* CARD 2: Turma A - Dinâmico com o primeiro curso (se houver) *@
            @if (Model.CourseSummaries != null && Model.CourseSummaries.Any())
            {
                var firstCourse = Model.CourseSummaries.First();
                <div class="card image-card">
                    <img src="~/images/caderno.png" alt="Caderno" />
                    <div>
                        <h3>@firstCourse.CourseName</h3> @* Nome do curso dinâmico *@
                        <p>@firstCourse.StudentsInCourse alunos</p> @* Total de alunos no curso dinâmico *@
                        <button>Ver turmas</button>
                    </div>
                </div>
            }
            else
            {
                <div class="card image-card">
                    <img src="~/images/caderno.png" alt="Caderno" />
                    <div>
                        <h3>Nenhuma Turma</h3>
                        <p>Nenhum aluno</p>
                        <button>Ver turmas</button>
                    </div>
                </div>
            }

            @* CARD 3: Resumo das Turmas (Total de Alunos) *@
            <div class="card blue">
                <h2>@Model.TotalStudents</h2>
                <p>Resumo das Turmas</p>
                <button>Gerar Relatório</button>
            </div>
        </section>

       
        


        <section class="recent-activities">
            <h3>Atividades Recentes</h3>
            @if (Model.RecentActivities != null && Model.RecentActivities.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>Atividade</th>
                            <th>Aluno</th>
                            <th>Status</th>
                            <th>Data</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var atividade in Model.RecentActivities)
                        {
                            <tr>
                                <td>@atividade.Acao</td>
                                <td>@atividade.Usuario</td>
                                <td>
                                    @if (atividade.Status != null && atividade.Status.ToLower() == "concluída")
                                    {
                                        <span class="status concluido">Concluída</span>
                                    }
                                    else
                                    {
                                        <span class="status andamento">@atividade.Status</span>
                                    }
                                </td>
                                <td>@atividade.DataHora.ToString("dd 'de' MMMM 'às' HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>Nenhuma atividade recente disponível no módulo.</p>
            }
        </section>
    </main>
</div>

<link rel="stylesheet" href="~/css/dashboard.css" />