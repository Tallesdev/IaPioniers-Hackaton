@model IaPioniers.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Visão Geral";
    Layout = "_Layout"; // Garante que este layout está sendo usado
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

<div class="main-content">
    <header class="top-header">
        <h1>Visão Geral</h1>
        <div class="user-profile">
            <span class="user-name">Prof. @Model.ProfessorNome</span>
        </div>
    </header>

    <section class="cards">
        @* CARD 1: Atividades *@
        <div class="card card-activities">
            <div class="card-icon"><i class="fas fa-tasks"></i></div>
            <div class="card-content">
                <span class="card-number">@Model.TotalActivities</span>
                <p class="card-title">Atividades</p>
            </div>
            <button class="card-button primary">Ver Atividades</button>
        </div>

        @* CARD 2: Turma A - Dinâmico com o primeiro curso (se houver) *@
        @if (Model.CourseSummaries != null && Model.CourseSummaries.Any())
        {
            var firstCourse = Model.CourseSummaries.First();
            <div class="card card-class">
                <img src="~/images/caderno.png" alt="Caderno" class="card-image" />
                <div class="card-content">
                    <span class="card-title">@firstCourse.CourseName</span>
                    <p class="card-details">@firstCourse.StudentsInCourse alunos</p>
                </div>
                <a asp-controller="Turmas" asp-action="Index" class="card-button secondary">Ver turmas</a>
            </div>
        }
        else
        {
            <div class="card card-class">
                <img src="~/images/caderno.png" alt="Caderno" class="card-image" />
                <div class="card-content">
                    <span class="card-title">Nenhuma Turma</span>
                    <p class="card-details">Nenhum aluno</p>
                </div>
                <a asp-controller="Turmas" asp-action="Index" class="card-button secondary">Ver turmas</a>
            </div>
        }

        @* CARD 3: Resumo das Turmas (Total de Alunos) *@
        <div class="card card-summary">
            <div class="card-icon"><i class="fas fa-users"></i></div>
            <div class="card-content">
                <span class="card-number">@Model.TotalStudents</span>
                <p class="card-title">Resumo das Turmas</p>
            </div>
            <button class="card-button primary">Gerar Relatório</button>
        </div>
    </section>

    <section class="recent-activities-table">
        <h3>Atividades Recentes</h3>
        @if (Model.RecentActivities != null && Model.RecentActivities.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Atividade</th>
                        <th>Aluno</th>
                        <th>Status</th>
                        <th>Data</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var atividade in Model.RecentActivities)
                    {
                        <tr>
                            <td>@atividade.Acao</td>
                            <td>@atividade.Usuario</td>
                            <td>
                                @{
                                    var statusClass = "";
                                    var statusText = atividade.Status;
                                    if (atividade.Status != null)
                                    {
                                        switch (atividade.Status.ToLower())
                                        {
                                            case "concluída":
                                                statusClass = "status-concluida";
                                                break;
                                            case "andamento":
                                                statusClass = "status-andamento";
                                                break;
                                            case "submetida": // Adicionei 'submetida' se a API retornar isso
                                                statusClass = "status-andamento"; // Pode ser o mesmo de 'em andamento'
                                                break;
                                            default:
                                                statusClass = "status-default";
                                                break;
                                        }
                                    }
                                }
                                <span class="status-dot @statusClass"></span> @statusText
                            </td>
                            @* CORREÇÃO AQUI: Garante que DataHora é DateTime antes de formatar *@
                            <td>@(atividade.DataHora != DateTime.MinValue ? atividade.DataHora.ToString("dd 'de' MMMM 'às' HH:mm") : "N/A")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="no-data-message">Nenhuma atividade recente disponível no módulo.</p>
        }
    </section>
</div>