@model IaPioniers.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Visão Geral";
}

<div class="dashboard-container">
    <aside class="sidebar">
        <h2>ATENA</h2>
        <nav>
            <a href="#">Início</a>
            <a href="#">Alunos</a>
            <a href="#">Turmas</a>
            <a href="#">Atividades</a>
            <a href="#">Configurações</a>
        </nav>
        <a href="#" class="logout">Sair</a>
    </aside>

    <main class="main-content">
        <header class="top-header">
            <h1>Visão Geral</h1>
            <div class="user-info">Prof. @Model.ProfessorNome</div>
        </header>

        <section class="cards">
            <div class="card blue">
                <h2>@Model.NumeroAtividades</h2>
                <p>Atividades</p>
                <button>Ver Atividades</button>
            </div>

            <div class="card image-card">
                <img src="~/images/caderno.png" alt="Caderno" />
                <div>
                    <h3>Turma A</h3>
                    <p>36 alunos</p>
                    <button>Ver turmas</button>
                </div>
            </div>

            <div class="card blue">
                <h2>@Model.TotalAlunos</h2>
                <p>Resumo das Turmas</p>
                <button>Gerar Relatório</button>
            </div>
        </section>

        <section class="recent-activities">
            <h3>Atividades Recentes</h3>
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Status</th>
                        <th>Data</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var atividade in Model.AtividadesRecentes)
                    {
                        <tr>
                            <td>@atividade.Usuario</td>
                            <td>
                                @if (atividade.Acao.ToLower() == "concluída")
                                {
                                    <span class="status concluido">Concluída</span>
                                }
                                else
                                {
                                    <span class="status andamento">@atividade.Acao</span>
                                }
                            </td>
                            <td>@atividade.DataHora.ToString("dd 'de' MMMM yyyy")</td>
                        </tr>
                    }

                </tbody>
            </table>
        </section>
    </main>
</div>

<link rel="stylesheet" href="~/css/dashboard.css" />

