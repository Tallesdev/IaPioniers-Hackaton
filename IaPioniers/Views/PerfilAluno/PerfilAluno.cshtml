<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perfil do Aluno - ATENA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f0f2f5;
        }

        .sidebar {
            width: 250px;
            background-color: #2c3e50; /* Azul escuro da sidebar */
            color: white;
            box-shadow: 2px 0 5px rgba(0,0,0,0.1);
        }

        .content-area {
            flex-grow: 1;
            padding: 2rem;
        }

        .card {
            background-color: white;
            border-radius: 0.75rem; /* Cantos arredondados */
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); /* Sombra suave */
            padding: 1.5rem;
        }
        /* Estilo para links ativos na sidebar */
        .sidebar-link.active {
            background-color: #3b82f6; /* Azul do link ativo */
        }
        /* Estilo para o checkmark do status */
        .status-checkmark {
            color: #22C55E; /* Verde do checkmark */
        }
        /* Responsividade para gráficos */
        canvas {
            max-width: 100%;
            height: auto; /* Permite que o canvas ajuste a altura automaticamente */
        }
    </style>
</head>
<body class="flex min-h-screen">
    <aside class="sidebar flex flex-col space-y-6 p-6">
        <div class="mb-8 text-center text-xl font-bold">ATENA</div>
        <nav class="space-y-4">
            <a href="#" class="sidebar-link flex items-center space-x-3 rounded-lg p-3 transition-colors duration-200 hover:bg-blue-700">
                <i class="fas fa-home"></i> <span>Início</span>
            </a>
            <a href="#" class="sidebar-link active flex items-center space-x-3 rounded-lg p-3 transition-colors duration-200">
                <i class="fas fa-user-graduate"></i> <span>Alunos</span>
            </a>
            <a href="#" class="sidebar-link flex items-center space-x-3 rounded-lg p-3 transition-colors duration-200 hover:bg-blue-700">
                <i class="fas fa-users"></i> <span>Turmas</span>
            </a>
            <a href="#" class="sidebar-link flex items-center space-x-3 rounded-lg p-3 transition-colors duration-200 hover:bg-blue-700">
                <i class="fas fa-tasks"></i> <span>Atividades</span>
            </a>
            <a href="#" class="sidebar-link flex items-center space-x-3 rounded-lg p-3 transition-colors duration-200 hover:bg-blue-700">
                <i class="fas fa-cog"></i> <span>Configurações</span>
            </a>
        </nav>
        <div class="mt-auto">
            <a href="#" class="sidebar-link flex items-center space-x-3 rounded-lg p-3 transition-colors duration-200 hover:bg-blue-700">
                <i class="fas fa-sign-out-alt"></i> <span>Sair</span>
            </a>
        </div>
    </aside>

    <main class="content-area">
        <header class="mb-8 flex items-center justify-between border-b border-gray-300 pb-4">
            <h1 class="text-3xl font-bold text-gray-800">Perfil Aluno</h1>
            <div class="flex items-center space-x-4">
                <span class="text-gray-600">Coordenador</span>
                <img src="https://placehold.co/40x40/4F46E5/FFFFFF?text=Coord" alt="Avatar Coordenador" class="h-10 w-10 rounded-full object-cover">
            </div>
        </header>

        <section class="card mb-8">
            <div class="mb-6 flex items-center space-x-6">
                <img src="https://placehold.co/80x80/6366F1/FFFFFF?text=Aluno" alt="Avatar Aluno" class="h-20 w-20 rounded-full object-cover">
                <div>
                    <h2 id="studentName" class="text-2xl font-semibold text-gray-800">Carregando...</h2>
                    <p class="flex items-center text-gray-600">
                        Status <span id="statusCheckmark" class="ml-2"></span><span id="studentStatus">Carregando...</span>
                    </p>
                </div>
            </div>
            <div class="mb-6 grid grid-cols-1 gap-4 text-gray-700 md:grid-cols-2">
                <p id="overallEvasionScore">Pontuação de Evasão: Carregando...</p>
                <p id="evasionReasons">Motivos de Evasão: Carregando...</p>
                <p id="lastAccess">Último Acesso: Carregando...</p>
                <p id="activityDiversity">Diversidade de atividade: Carregando...</p>
            </div>
            <div class="flex flex-col space-y-3 sm:flex-row sm:space-x-4 sm:space-y-0">
                <button class="flex items-center justify-center space-x-2 rounded-full bg-gray-200 px-4 py-2 text-gray-800 transition-colors duration-200 hover:bg-gray-300">
                    <i class="fas fa-chart-line"></i> <span>Ver Atividades do Aluno</span>
                </button>
                <button class="flex items-center justify-center space-x-2 rounded-full bg-gray-200 px-4 py-2 text-gray-800 transition-colors duration-200 hover:bg-gray-300">
                    <i class="fas fa-envelope"></i> <span>Enviar mensagem</span>
                </button>
                <button class="flex items-center justify-center space-x-2 rounded-full bg-gray-200 px-4 py-2 text-gray-800 transition-colors duration-200 hover:bg-gray-300">
                    <i class="fas fa-clipboard"></i> <span>Registrar observação</span>
                </button>
            </div>
        </section>

        <section class="grid grid-cols-1 gap-8 lg:grid-cols-2">
            <div class="card">
                <h3 class="mb-4 text-lg font-semibold">Logs Recentes</h3>
                <div class="h-64 overflow-y-auto">
                    <ul id="recentLogsList" class="list-inside list-disc text-gray-700">
                        <li>Carregando logs...</li>
                    </ul>
                </div>
            </div>
            <div class="card flex flex-col justify-between">
                <h3 class="mb-4 text-lg font-semibold">Atividades por Curso</h3>
                <div style="height: 300px;">
                    <canvas id="courseActivityChart"></canvas>
                </div>
                <div class="mt-4 flex justify-center">
                    <ul id="courseActivityLegend" class="m-0 grid list-none grid-cols-2 gap-2 p-0 text-sm">
                        </ul>
                </div>
            </div>
        </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        /**
         * Extrai o ID do aluno da URL.
         * Assume que a URL é algo como `/student/123` ou `/profile?id=123`.
         * Você precisará adaptar isso à sua estrutura de roteamento.
         */
        function getStudentIdFromUrl() {
            // Exemplo para URL como '/student/123'
            const pathSegments = window.location.pathname.split('/');
            // Pega o último segmento se a URL for /student/ID_DO_ALUNO
            // Ou o penúltimo se houver algo como /student/ID_DO_ALUNO/dashboard
            const studentId = pathSegments[pathSegments.length - 1]; 
            return studentId;

            // Se você usar parâmetros de consulta (ex: ?id=123):
            // const urlParams = new URLSearchParams(window.location.search);
            // return urlParams.get('id');
        }

        /**
         * Busca o perfil do aluno da API Flask.
         */
        async function fetchStudentProfile(userId) {
            try {
                // A URL deve ser ajustada para o endereço da sua API
                const response = await fetch(`/api/student/student-profile/${userId}`);
                if (!response.ok) {
                    const errorData = await response.json();
                    console.error('Erro ao buscar perfil do aluno:', errorData.error);
                    return null;
                }
                const profileData = await response.json();
                return profileData;
            } catch (error) {
                console.error('Erro de rede ou ao processar resposta:', error);
                return null;
            }
        }

        /**
         * Atualiza os elementos da interface do usuário com os dados do perfil do aluno.
         *  {Object} profile - Objeto contendo os dados do perfil do aluno.
         */
        function updateUIWithProfileData(profile) {
            document.getElementById('studentName').innerText = profile.user_name || 'Nome Desconhecido';

            const studentStatusElement = document.getElementById('studentStatus');
            const statusCheckmarkElement = document.getElementById('statusCheckmark');
            const evasionReasonsElement = document.getElementById('evasionReasons');
            const overallEvasionScoreElement = document.getElementById('overallEvasionScore');

            // Lógica para status de risco de evasão
            if (profile.is_at_risk) {
                studentStatusElement.innerText = "Em Risco de Evasão";
                studentStatusElement.classList.remove('text-green-500');
                studentStatusElement.classList.add('text-red-500');
                statusCheckmarkElement.innerHTML = `
                    <i class="fas fa-exclamation-triangle text-red-500"></i>
                `; // Ícone de aviso
            } else {
                studentStatusElement.innerText = "Participando Ativamente";
                studentStatusElement.classList.remove('text-red-500');
                studentStatusElement.classList.add('text-green-500');
                statusCheckmarkElement.innerHTML = `
                    <svg class="status-checkmark" fill="currentColor" height="20" width="20" viewBox="0 0 24 24">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                    </svg>
                `; // Ícone de checkmark
            }

            overallEvasionScoreElement.innerText = `Pontuação de Risco de Evasão: ${profile.overall_evasion_score.toFixed(4)}`;

            if (profile.evasion_reasons && profile.evasion_reasons.length > 0) {
                evasionReasonsElement.innerText = `Motivos de Evasão: ${profile.evasion_reasons.join(', ')}`;
            } else {
                evasionReasonsElement.innerText = `Motivos de Evasão: Nenhum aparente`;
            }

            // Atualiza a data do último acesso e diversidade de atividade usando global_activity
            const lastAccessDate = profile.global_activity && profile.global_activity.last_access_date ?
                new Date(profile.global_activity.last_access_date).toLocaleDateString('pt-BR') : 'N/A';
            document.getElementById('lastAccess').innerText = `Último Acesso: ${lastAccessDate}`;

            const activityDiversityScore = profile.global_activity && profile.global_activity.activity_diversity_score !== undefined ?
                profile.global_activity.activity_diversity_score : 'N/A';
            const totalActivityTypes = profile.global_activity && profile.global_activity.total_activity_types !== undefined ?
                profile.global_activity.total_activity_types : 'N/A';
            document.getElementById('activityDiversity').innerText = `Diversidade de Atividade: ${activityDiversityScore} de ${totalActivityTypes}`;

            // Preenche os logs recentes
            const recentLogsList = document.getElementById('recentLogsList');
            recentLogsList.innerHTML = ''; // Limpa a lista existente
            if (profile.detailed_recent_logs && profile.detailed_recent_logs.length > 0) {
                profile.detailed_recent_logs.forEach(log => {
                    const listItem = document.createElement('li');
                    const logDate = new Date(log.date).toLocaleString('pt-BR');
                    listItem.textContent = `${logDate}: ${log.action} em ${log.course_fullname}`;
                    recentLogsList.appendChild(listItem);
                });
            } else {
                recentLogsList.innerHTML = '<li>Nenhum log recente encontrado.</li>';
            }

            // Desenha o gráfico de atividades por curso
            drawCourseActivityChart(profile.course_activity);
        }

        /**
         * Desenha o gráfico de atividades por curso (doughnut) usando Chart.js.
         *  {Array<Object>} data - Array de objetos com 'course_fullname' e 'total_activities'.
         */
        function drawCourseActivityChart(data) {
            const ctx = document.getElementById('courseActivityChart').getContext('2d');

            if (!data || data.length === 0) {
                // Se não houver dados, exibe uma mensagem
                ctx.font = "16px Inter";
                ctx.fillStyle = "#6B7280"; // text-gray-500
                ctx.textAlign = "center";
                ctx.textBaseline = "middle";
                ctx.fillText("Nenhuma atividade por curso encontrada.", ctx.canvas.width / 2, ctx.canvas.height / 2);
                return;
            }

            const labels = data.map(item => item.course_fullname);
            const totalActivities = data.map(item => item.total_activities);

            // Gerar cores dinamicamente
            const backgroundColors = generateRandomColors(data.length);

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: totalActivities,
                        backgroundColor: backgroundColors,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false // A legenda será gerada manualmente
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed !== null) {
                                        label += context.parsed + ' atividades';
                                    }
                                    return label;
                                }
                            }
                        }
                    }
                }
            });

            // Gerar legenda personalizada
            const legendContainer = document.getElementById('courseActivityLegend');
            legendContainer.innerHTML = '';
            data.forEach((item, index) => {
                const listItem = document.createElement('li');
                listItem.classList.add('flex', 'items-center');
                listItem.innerHTML = `<span class="mr-2 h-3 w-3 rounded-full" style="background-color: ${backgroundColors[index]}"></span>${item.course_fullname}`;
                legendContainer.appendChild(listItem);
            });
        }

        /**
         * Gera um array de cores hexadecimais aleatórias.
         *  {number} numColors - O número de cores a serem geradas.
         *  {Array<string>} Um array de strings de cores hexadecimais.
         */
        function generateRandomColors(numColors) {
            const colors = [];
            for (let i = 0; i < numColors; i++) {
                const hue = (i * 137.508) % 360; // Usa o "golden angle" para boa distribuição
                colors.push(`hsl(${hue}, 70%, 60%)`);
            }
            return colors;
        }


        // Evento que garante que o DOM está completamente carregado antes de executar o script
        document.addEventListener('DOMContentLoaded', async () => {
            const studentId = getStudentIdFromUrl(); // Obtém o ID do aluno da URL

            if (!studentId) {
                console.error("ID do aluno não encontrado na URL.");
                document.getElementById('studentName').innerText = "Erro: ID do Aluno Não Fornecido";
                return;
            }

            console.log(`Carregando perfil para o aluno com ID: ${studentId}`);

            const studentProfile = await fetchStudentProfile(studentId);

            if (studentProfile) {
                updateUIWithProfileData(studentProfile);
            } else {
                document.getElementById('studentName').innerText = "Perfil do Aluno Não Encontrado";
                document.getElementById('studentStatus').innerText = "Erro ao Carregar";
                document.getElementById('lastAccess').innerText = "Último Acesso: N/A";
                document.getElementById('activityDiversity').innerText = "Diversidade de atividade: N/A";
                document.getElementById('overallEvasionScore').innerText = "Pontuação de Evasão: N/A";
                document.getElementById('evasionReasons').innerText = "Motivos de Evasão: N/A";
                document.getElementById('recentLogsList').innerHTML = '<li>Não foi possível carregar os logs recentes.</li>';
                console.error("Não foi possível carregar o perfil do aluno.");
            }
        });
    </script>
</body>
</html>