﻿
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ATENA</title>

    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />

    <script src="https://kit.fontawesome.com/SUA_CHAVE_DO_FONT_AWESOME.js" crossorigin="anonymous"></script>

    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="app-container">
        <aside id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <h2>ATENA</h2>
                <button id="sidebarToggle" class="sidebar-toggle-btn">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a asp-controller="Dashboard" asp-action="Index"><i class="fas fa-home"></i> <span>Início</span></a></li>
                    <li><a href="#"><i class="fas fa-user-friends"></i> <span>Alunos</span></a></li>
                    <li><a href="#"><i class="fas fa-users"></i> <span>Turmas</span></a></li>
                    <li><a href="#"><i class="fas fa-clipboard-list"></i> <span>Atividades</span></a></li>
                    <li><a href="#"><i class="fas fa-cog"></i> <span>Configurações</span></a></li>
                </ul>
            </nav>
            <div class="sidebar-footer">
                <a href="#"><i class="fas fa-sign-out-alt"></i> <span>Sair</span></a>
            </div>
        </aside>

        <main id="main-content" class="main-content">
            <header class="top-bar">
                <div class="top-bar-left">
                    <h1>@ViewData["Title"]</h1>
                </div>
                <div class="top-bar-right">
                    <span>Prof. @ViewData["ProfessorNome"]</span> <img src="~/images/avatar.png" alt="Foto Perfil" class="profile-pic">
                    @if (ViewData["CurrentModuleDisplayName"] != null && !string.IsNullOrEmpty(ViewData["CurrentModuleDisplayName"].ToString()))
                    {
                        <div class="module-info">@ViewData["CurrentModuleDisplayName"]</div>
                    }
                </div>
            </header>

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/dashboard.js"></script> @RenderSection("Scripts", required: false)
</body>
</html>