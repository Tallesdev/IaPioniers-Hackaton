@model IaPioniers.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Resumo de Dados"; // Novo título da página, conforme o protótipo
}

<head>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
</head>

<style>
    /* ------------------------------------ */
    /* Estilos Gerais do Body e Container */
    /* ------------------------------------ */
    body {
        font-family: 'Inter', sans-serif;
        background-color: #f4f7f6; /* Cor de fundo geral */
        margin: 0;
        padding: 0;
        display: flex; /* Habilita layout de sidebar e conteúdo principal */
        min-height: 100vh; /* Garante que o body ocupe toda a altura da viewport */
    }

    /* Container Principal do Dashboard */
    .dashboard-container {
        display: flex;
        width: 100%;
        max-width: 1400px; /* Limita a largura máxima para melhor visualização em telas grandes */
        margin: 0 auto; /* Centraliza o container */
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08); /* Sombra suave para o container */
        border-radius: 15px; /* Cantos arredondados para todo o dashboard */
        overflow: hidden; /* Garante que o conteúdo respeite os cantos arredondados */
    }

    /* ------------------------------------ */
    /* Sidebar (Menu Lateral) */
    /* ------------------------------------ */
    .sidebar {
        width: 250px;
        background-color: #363740; /* Cor de fundo escura */
        color: #a4a6b3; /* Cor do texto padrão */
        padding: 30px 0; /* Preenchimento superior e inferior */
        display: flex;
        flex-direction: column;
        justify-content: space-between; /* Espaça o logo/nav do logout */
        box-shadow: 2px 0 8px rgba(0,0,0,0.15); /* Sombra para a direita */
        flex-shrink: 0; /* Impede que a sidebar encolha */
    }

    .sidebar h2 {
        color: #7B3E90; /* Cor ATENA (roxo) */
        text-align: center;
        margin-bottom: 40px;
        font-size: 2.2em;
        font-weight: 700; /* Bold */
        letter-spacing: 1px;
    }

    .sidebar nav {
        flex-grow: 1; /* Permite que a navegação ocupe espaço disponível */
    }

    .sidebar nav a {
        padding: 18px 25px; /* Mais preenchimento para itens de menu */
        color: #a4a6b3;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 15px;
        font-size: 1.1em;
        transition: background-color 0.3s ease, color 0.3s ease;
        border-left: 5px solid transparent; /* Para o indicador de ativo */
    }

    .sidebar nav a:hover {
        background-color: #4e4f5a; /* Fundo mais escuro ao passar o mouse */
        color: #fff; /* Texto branco ao passar o mouse */
    }

    .sidebar nav a.active {
        background-color: #4e4f5a;
        color: #fff;
        border-left-color: #007bff; /* Linha azul para item ativo */
        font-weight: 600; /* Semibold para item ativo */
    }

    .sidebar .logout {
        padding: 18px 25px;
        color: #a4a6b3;
        text-decoration: none;
        text-align: center;
        border-top: 1px solid #4e4f5a; /* Separador superior */
        margin-top: 30px;
        transition: background-color 0.3s ease, color 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 1.1em;
    }

    .sidebar .logout:hover {
        background-color: #dc3545; /* Vermelho ao passar o mouse */
        color: #fff;
    }

    /* ------------------------------------ */
    /* Ícones da Sidebar (Font Awesome) */
    /* ------------------------------------ */
    .sidebar nav a i {
        width: 20px; /* Largura fixa para ícones */
        text-align: center;
        font-size: 1.2em;
    }

    /* ------------------------------------ */
    /* Conteúdo Principal (Main Content) */
    /* ------------------------------------ */
    .main-content {
        flex-grow: 1; /* Ocupa o espaço restante */
        padding: 30px 40px; /* Preenchimento interno */
        background-color: #f8fcfd; /* Cor de fundo clara */
    }

    .top-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        border-bottom: 1px solid #e0e7eb; /* Linha fina de separação */
        padding-bottom: 15px;
    }

    .top-header h1 {
        margin: 0;
        font-size: 2.5em;
        color: #333;
        font-weight: 700;
        border-bottom: none; /* Remove bordas adicionais */
        padding-bottom: 0;
    }

    .user-info {
        font-weight: 600; /* Semibold */
        color: #555;
        display: flex;
        align-items: center;
        gap: 12px; /* Espaçamento entre nome e imagem */
    }

    .user-info img {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #007bff; /* Borda azul ao redor da imagem */
    }

    /* ------------------------------------ */
    /* Seção de Cartões (Cards Section) */
    /* ------------------------------------ */
    .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); /* Layout responsivo de grid */
        gap: 30px; /* Espaçamento maior entre os cartões */
        margin-bottom: 40px;
    }

    .card-resumo {
        background-color: #fff;
        border-radius: 15px; /* Mais arredondado */
        padding: 30px;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1); /* Sombra mais pronunciada */
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        color: #fff;
        height: 200px; /* Altura um pouco maior para melhor visual */
        transition: transform 0.3s ease-in-out, box-shadow 0.3s ease;
    }

    .card-resumo:hover {
        transform: translateY(-8px); /* Efeito de elevação ao passar o mouse */
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .card-resumo.evasao {
        background: linear-gradient(135deg, #FF4500, #FF6347); /* Tom de vermelho mais vibrante para evasão */
    }

    .card-resumo.relatorio {
        background: linear-gradient(135deg, #1E90FF, #6495ED); /* Tom de azul mais vibrante para relatório */
    }

    .card-resumo h2 {
        font-size: 5.5em; /* Número grande */
        margin: 0;
        line-height: 1;
        color: #fff;
        border-bottom: none;
        padding-bottom: 0;
        font-weight: 700;
    }

    .card-resumo p {
        font-size: 1.4em; /* Texto maior */
        margin-top: 15px;
        color: #fff;
        font-weight: 600;
    }

    .card-resumo button {
        background-color: rgba(255, 255, 255, 0.25); /* Fundo branco semi-transparente */
        border: 1px solid rgba(255, 255, 255, 0.6); /* Borda branca semi-transparente */
        color: #fff;
        padding: 12px 25px;
        border-radius: 25px; /* Botão mais arredondado */
        cursor: pointer;
        font-size: 1.1em;
        margin-top: 20px;
        transition: background-color 0.3s ease, border-color 0.3s ease, transform 0.2s ease;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .card-resumo button:hover {
        background-color: rgba(255, 255, 255, 0.4);
        border-color: #fff;
        transform: scale(1.05); /* Pequeno zoom no hover */
    }

    /* ------------------------------------ */
    /* Seção da Tabela de Alunos */
    /* ------------------------------------ */
    .students-table-section {
        background-color: #fff;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    }

    .filter-section {
        display: flex;
        align-items: center;
        gap: 20px; /* Espaçamento maior */
        margin-bottom: 30px;
    }

    .filter-section label {
        font-weight: 700;
        color: #333;
        font-size: 1.1em;
    }

    .filter-section select {
        padding: 12px 20px; /* Mais preenchimento */
        border: 1px solid #ddd;
        border-radius: 10px; /* Mais arredondado */
        font-size: 1em;
        cursor: pointer;
        outline: none;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
        min-width: 200px;
    }

    .filter-section select:focus {
        border-color: #007bff;
        box-shadow: 0 0 0 4px rgba(0, 123, 255, 0.25);
    }

    .students-table-section h3 {
        margin-top: 0;
        color: #333;
        font-size: 2em;
        border-bottom: 1px solid #e0e7eb;
        padding-bottom: 15px;
        margin-bottom: 25px;
        font-weight: 700;
    }

    .students-table-section table {
        width: 100%;
        border-collapse: collapse;
        border-radius: 10px; /* Cantos arredondados para a tabela inteira */
        overflow: hidden; /* Garante que os cantos arredondados cortem o conteúdo */
    }

    .students-table-section th,
    .students-table-section td {
        border: 1px solid #f0f0f0; /* Borda mais clara */
        padding: 15px 20px;
        text-align: left;
        vertical-align: middle; /* Alinha o conteúdo verticalmente */
    }

    .students-table-section th {
        background-color: #eef4f7; /* Fundo do cabeçalho mais claro */
        font-weight: 700;
        color: #555;
        text-transform: uppercase;
        font-size: 0.95em;
        letter-spacing: 0.5px;
    }

    .students-table-section tr:nth-child(even) {
        background-color: #fdfefe;
    }

    .students-table-section tr:hover {
        background-color: #e8f5fe; /* Fundo mais claro no hover */
        cursor: pointer;
    }

    /* Estilo para a probabilidade de evasão (bolinhas coloridas) */
    .evasion-probability-cell {
        display: flex;
        align-items: center;
        gap: 10px; /* Espaçamento entre bolinha e texto */
        font-weight: 600;
    }

    .evasion-dot {
        width: 14px; /* Bolinha um pouco maior */
        height: 14px;
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0; /* Impede que a bolinha encolha */
        border: 1px solid rgba(0,0,0,0.1); /* Pequena borda para definição */
    }

    .evasion-dot.green { background-color: #28a745; } /* Baixo risco */
    .evasion-dot.orange { background-color: #ffc107; } /* Médio risco */
    .evasion-dot.red { background-color: #dc3545; } /* Alto risco */

    .email-icon {
        color: #007bff; /* Azul vibrante */
        cursor: pointer;
        margin-left: 10px; /* Mais espaço à esquerda */
        font-size: 1.2em; /* Ícone um pouco maior */
        transition: color 0.2s ease, transform 0.2s ease;
    }
    .email-icon:hover {
        color: #0056b3;
        transform: scale(1.1); /* Pequeno zoom no hover */
    }

    /* Estilos para o Modal/Popup de E-mail */
    .email-modal {
        display: none; /* Escondido por padrão */
        position: fixed; /* Fixado na tela */
        z-index: 1000; /* Acima de outros elementos */
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0,0,0,0.6); /* Fundo escuro semi-transparente */
        justify-content: center;
        align-items: center;
    }

    .email-modal-content {
        background-color: #fff;
        margin: auto;
        padding: 30px;
        border-radius: 15px;
        width: 90%;
        max-width: 700px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        position: relative;
        animation: fadeIn 0.3s ease-out; /* Animação de fade-in */
    }

    .email-modal-content h3 {
        margin-top: 0;
        color: #333;
        font-size: 1.8em;
        border-bottom: 1px solid #e0e7eb;
        padding-bottom: 10px;
        margin-bottom: 20px;
    }

    .email-modal-content textarea {
        width: calc(100% - 20px); /* Ajusta largura com padding */
        height: 250px;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 1em;
        line-height: 1.5;
        resize: vertical;
        margin-bottom: 20px;
    }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .modal-actions button {
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 1em;
        transition: background-color 0.2s ease;
    }

    .modal-actions .copy-btn {
        background-color: #007bff;
        color: #fff;
        border: none;
    }

    .modal-actions .copy-btn:hover {
        background-color: #0056b3;
    }

    .modal-actions .close-btn {
        background-color: #ccc;
        color: #333;
        border: none;
    }

    .modal-actions .close-btn:hover {
        background-color: #bbb;
    }

    .loading-indicator {
        text-align: center;
        padding: 20px;
        font-size: 1.2em;
        color: #007bff;
        display: none; /* Escondido por padrão */
    }

    /* Keyframe para animação de fade-in */
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Responsividade */
    @@media (max-width: 1024px) {
        .dashboard-container {
            margin: 15px;
            border-radius: 10px;
        }
        .main-content {
            padding: 20px 25px;
        }
        .top-header h1 {
            font-size: 2em;
        }
        .cards {
            grid-template-columns: 1fr; /* Cartões em uma única coluna */
        }
        .card-resumo {
            height: 180px; /* Mantém altura no tablet */
        }
    }

    @@media (max-width: 768px) {
        body {
            flex-direction: column; /* Empilha sidebar e conteúdo */
        }
        .sidebar {
            width: 100%;
            height: auto;
            padding: 15px 0;
            flex-direction: row; /* Itens da sidebar em linha */
            flex-wrap: wrap; /* Permite quebrar linha se muitos itens */
            justify-content: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15); /* Sombra abaixo */
        }
        .sidebar h2 {
            width: 100%;
            margin-bottom: 15px;
            font-size: 1.5em;
        }
        .sidebar nav {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            width: 100%;
        }
        .sidebar nav a {
            padding: 10px 15px;
            font-size: 0.9em;
            border-left: none; /* Remove linha lateral */
            border-bottom: 3px solid transparent; /* Adiciona linha inferior para ativo */
        }
        .sidebar nav a.active {
            border-left-color: transparent;
            border-bottom-color: #007bff; /* Linha azul para item ativo abaixo */
        }
        .sidebar .logout {
            width: 100%;
            text-align: center;
            margin-top: 15px;
            border-top: none;
            padding: 10px 0;
            background-color: #4e4f5a; /* Mantém fundo para botão de logout */
        }

        .main-content {
            padding: 15px;
        }
        .top-header {
            flex-direction: column;
            align-items: flex-start;
            margin-bottom: 25px;
            padding-bottom: 10px;
        }
        .top-header h1 {
            font-size: 1.8em;
            margin-bottom: 10px;
        }
        .user-info {
            width: 100%;
            justify-content: flex-start;
        }
        .user-info img {
            width: 35px;
            height: 35px;
        }
        .cards {
            gap: 20px;
        }
        .card-resumo {
            height: 160px; /* Reduz altura no mobile */
            padding: 20px;
        }
        .card-resumo h2 {
            font-size: 4em;
        }
        .card-resumo p {
            font-size: 1.1em;
        }
        .card-resumo button {
            padding: 10px 20px;
            font-size: 0.9em;
        }
        .filter-section {
            flex-direction: column;
            align-items: flex-start;
            gap: 10px;
        }
        .filter-section select {
            width: 100%; /* Ocupa largura total */
            min-width: unset;
        }
        .students-table-section h3 {
            font-size: 1.6em;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }
        .students-table-section th,
        .students-table-section td {
            padding: 10px 12px;
            font-size: 0.8em;
        }
        .evasion-dot {
            width: 10px;
            height: 10px;
        }
        .email-icon {
            font-size: 1em;
            margin-left: 5px;
        }
</style>

<div class="dashboard-container">
    <aside class="sidebar">
        <h2>ATENA</h2>
        <nav>
            <a href="#"><i class="fas fa-home"></i>Início</a>
            <a href="#"><i class="fas fa-user-graduate"></i>Alunos</a>
            <a href="#"><i class="fas fa-users"></i>Turmas</a>
            <a href="#" class="active"><i class="fas fa-clipboard-list"></i>Atividades</a> @* Marcando "Atividades" como ativo *@
            <a href="#"><i class="fas fa-cog"></i>Configurações</a>
        </nav>
        <a href="#" class="logout"><i class="fas fa-sign-out-alt"></i>Sair</a>
    </aside>

    <main class="main-content">
        <header class="top-header">
            <h1>Resumo de Dados</h1> @* Título conforme protótipo *@
            <div class="user-info">
                Prof. @Model.ProfessorNome
                <img src="https://placehold.co/40x40/7B3E90/FFFFFF?text=P" alt="Foto do Professor" onerror="this.onerror=null;this.src='https://placehold.co/40x40/7B3E90/FFFFFF?text=P';">
            </div>
        </header>

        <section class="cards">
            <div class="card-resumo evasao">
                <h2>@Model.EvasionRiskCount</h2> @* Assumindo que Model.EvasionRiskCount contém o número "10" *@
                <p>Risco de Evasão</p>
                <button>Detalhes</button>
            </div>
            <div class="card-resumo relatorio">
                <h2>Relatório da Turma</h2> @* Texto do protótipo *@
                <p>Gerar Relatório</p>
                <button>Gerar</button>
            </div>
        </section>

        <section class="students-table-section">
            <div class="filter-section">
                <label for="courseSelect">Turma:</label>
                <select id="courseSelect">
                    @* Assumindo que Model.CourseSummaries está populado para o dropdown *@
                    @if (Model.CourseSummaries != null && Model.CourseSummaries.Any())
                    {
                        @foreach (var course in Model.CourseSummaries)
                        {
                            <option value="@course.CourseName">@course.CourseName</option>
                        }
                    }
                    else
                    {
                        <option value="">Nenhuma Turma Disponível</option>
                    }
                </select>
            </div>

            <h3>Lista de Alunos</h3>
            @if (Model.StudentEvasionList != null && Model.StudentEvasionList.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>Lista de Alunos</th>
                            <th>Total de Acessos</th>
                            <th>Dias sem Acesso</th>
                            <th>Probabilidade de Evasão</th>
                            <th>Ações</th> 
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model.StudentEvasionList)
                        {
                            <tr>
                                <td>
                                    @student.StudentName
                                    <span class="email-icon" onclick="alert('Enviar email para @student.StudentName');">
                                        <i class="fas fa-envelope"></i> @* Ícone de email do Font Awesome *@
                                    </span>
                                </td>
                                <td>@student.TotalAccesses</td>
                                <td>@student.DaysWithoutAccess</td>
                                <td class="evasion-probability-cell">
                                    @{
                                        string dotClass = "";
                                        if (student.EvasionProbability <= 25) { dotClass = "green"; }
                                        else if (student.EvasionProbability <= 60) { dotClass = "orange"; }
                                        else { dotClass = "red"; }
                                    }
                                    <span class="evasion-dot @dotClass"></span>
                                    @student.EvasionProbability%
                                </td>
                                <td>
                                    <button class="generate-email-btn"
                                            data-student-name="@student.StudentName"
                                            data-evasion-probability="@student.EvasionProbability"
                                            data-days-without-access="@student.DaysWithoutAccess">
                                        Gerar Email ✨
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="no-data">Nenhum dado de evasão de alunos disponível.</p>
            }
        </section>
    </main>
</div>

<!-- Modal para exibir o rascunho do e-mail -->
<div id="emailModal" class="email-modal">
    <div class="email-modal-content">
        <h3>Rascunho de E-mail para <span id="modalStudentName"></span></h3>
        <div class="loading-indicator" id="loadingIndicator">Gerando e-mail... <i class="fas fa-spinner fa-spin"></i></div>
        <textarea id="emailDraftTextarea" readonly></textarea>
        <div class="modal-actions">
            <button class="copy-btn" onclick="copyEmailDraft()">Copiar</button>
            <button class="close-btn" onclick="closeEmailModal()">Fechar</button>
        </div>
    </div>
</div>

<script>
    // Função para abrir o modal de e-mail e gerar o rascunho
    document.querySelectorAll('.generate-email-btn').forEach(button => {
        button.addEventListener('click', async function() {
            const studentName = this.dataset.studentName;
            const evasionProbability = this.dataset.evasionProbability;
            const daysWithoutAccess = this.dataset.daysWithoutAccess;

            // Exibe o modal e o indicador de carregamento
            document.getElementById('emailModal').style.display = 'flex';
            document.getElementById('modalStudentName').textContent = studentName;
            document.getElementById('loadingIndicator').style.display = 'block';
            document.getElementById('emailDraftTextarea').value = ''; // Limpa o textarea

            // Constroi o prompt para o LLM
            const prompt = `Gere um rascunho de e-mail breve e empatico de um professor para um aluno. O nome do aluno é ${studentName}. A probabilidade de evasão dele(a) é de ${evasionProbability}%, e ele(a) não acessa a plataforma há ${daysWithoutAccess} dias. O e-mail deve expressar preocupação, oferecer suporte e gentilmente encorajá-lo(a) a se reengajar, sem soar acusatório. Mantenha o e-mail conciso e em Português do Brasil.`;

            try {
                // Chama a API Gemini para gerar o e-mail
                let chatHistory = [];
                chatHistory.push({ role: "user", parts: [{ text: prompt }] });
                const payload = { contents: chatHistory };
                const apiKey = ""; // API key será fornecida pelo ambiente
                const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${apiKey}`;

                const response = await fetch(apiUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    throw new Error(`Erro na API Gemini: ${response.status} - ${response.statusText}`);
                }

                const result = await response.json();
                
                let generatedText = "Não foi possível gerar o e-mail. Tente novamente.";
                if (result.candidates && result.candidates.length > 0 &&
                    result.candidates[0].content && result.candidates[0].content.parts &&
                    result.candidates[0].content.parts.length > 0) {
                    generatedText = result.candidates[0].content.parts[0].text;
                } else {
                    console.error("Estrutura de resposta inesperada da API Gemini:", result);
                }
                
                // Exibe o texto gerado
                document.getElementById('emailDraftTextarea').value = generatedText;

            } catch (error) {
                console.error("Erro ao gerar e-mail com a API Gemini:", error);
                document.getElementById('emailDraftTextarea').value = `Erro ao gerar e-mail: ${error.message}`;
            } finally {
                // Esconde o indicador de carregamento
                document.getElementById('loadingIndicator').style.display = 'none';
            }
        });
    });

    // Função para fechar o modal de e-mail
    function closeEmailModal() {
        document.getElementById('emailModal').style.display = 'none';
        document.getElementById('emailDraftTextarea').value = ''; // Limpa o conteúdo ao fechar
    }

    // Função para copiar o texto do rascunho para a área de transferência
    function copyEmailDraft() {
        const textarea = document.getElementById('emailDraftTextarea');
        textarea.select();
        document.execCommand('copy'); // Comando de cópia para navegadores antigos/iFrames
        alert('Rascunho de e-mail copiado para a área de transferência!');
    }

    // Lógica JavaScript para o dropdown (mantido da versão anterior, se necessário)
    document.addEventListener('DOMContentLoaded', function() {
        const courseSelect = document.getElementById('courseSelect');
        if (courseSelect) {
            courseSelect.addEventListener('change', function() {
                console.log('Turma selecionada:', this.value);
                // Adicione lógica para filtrar a tabela ou recarregar dados aqui
            });
        }
    });

</script>
