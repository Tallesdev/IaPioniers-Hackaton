@{
    ViewData["Title"] = "Login / Cadastro";
    Layout = "_LoginLayout";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Atena</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

    <style>
        /* (mantido todo o CSS original que você já tinha) */
        body {
            margin: 0;
            padding: 0;
            font-family: 'Roboto', Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: #f0f2f5;
            overflow: hidden;
        }

        .background-blur {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('/images/fundo_atena.png');
            background-size: cover;
            background-position: center;
            filter: blur(8px);
            -webkit-filter: blur(8px);
            z-index: 1;
        }

        .background-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.3);
            z-index: 2;
        }

        .login-container {
            background-color: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 50px 40px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
            text-align: center;
            width: 420px;
            max-width: 95%;
            position: relative;
            z-index: 3;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .logo {
            font-size: 3.2em;
            font-weight: 700;
            color: #3f51b5;
            margin-bottom: 40px;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.1);
            letter-spacing: 2px;
        }

        .header-tabs {
            display: flex;
            margin-bottom: 35px;
            background-color: #e8eaf6;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            width: 100%;
        }

        .header-tab {
            flex-grow: 1;
            padding: 15px 0;
            cursor: pointer;
            font-weight: 600;
            font-size: 1.1em;
            color: #7986cb;
            transition: all 0.3s ease;
            text-transform: uppercase;
        }

            .header-tab.active {
                background-color: #3f51b5;
                color: #fff;
                box-shadow: inset 0 3px 0 0 rgba(0,0,0,0.2);
            }

            .header-tab:not(.active):hover {
                background-color: #c5cae9;
                color: #3f51b5;
            }

        .form-group {
            margin-bottom: 25px;
            text-align: left;
            width: 100%;
        }

            .form-group label {
                display: block;
                margin-bottom: 10px;
                font-weight: 500;
                color: #5c6bc0;
                font-size: 0.95em;
            }

            .form-group input {
                width: calc(100% - 24px);
                padding: 12px;
                border: 1px solid #e0e0e0;
                border-radius: 8px;
                background-color: #ffffff;
                color: #333;
                font-size: 1em;
                transition: all 0.3s ease;
            }

                .form-group input:focus {
                    outline: none;
                    border-color: #7986cb;
                    box-shadow: 0 0 0 3px rgba(63, 81, 181, 0.2);
                }

        .form-actions button {
            background-color: #3f51b5;
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 1.2em;
            font-weight: 600;
            transition: background-color 0.3s ease, transform 0.2s ease;
            width: 100%;
            margin-top: 20px;
            letter-spacing: 1px;
        }

            .form-actions button:hover {
                background-color: #303f9f;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            }

        #loginForm, #cadastroForm {
            display: none;
        }

            #loginForm.active, #cadastroForm.active {
                display: block;
            }
    </style>
</head>
<body>
    <div class="background-blur"></div>
    <div class="background-overlay"></div>

    <div class="login-container">
        <div class="logo">ATENA</div>

        <div class="header-tabs">
            <div class="header-tab active" id="loginTab">LOGIN</div>
            <div class="header-tab" id="cadastroTab">CADASTRAR</div>
        </div>

        <form id="loginForm" class="active">
            <div class="form-group">
                <label for="loginEmail">E-MAIL :</label>
                <input type="email" id="loginEmail" name="email" required />
            </div>
            <div class="form-group">
                <label for="loginSenha">SENHA :</label>
                <input type="password" id="loginSenha" name="password" required />
            </div>
            <div class="form-actions">
                <button type="submit">ACESSAR</button>
            </div>
        </form>

        <form id="cadastroForm">
            <div class="form-group">
                <label for="cadastroNome">NOME :</label>
                <input type="text" id="cadastroNome" name="nome" required />
            </div>
            <div class="form-group">
                <label for="cadastroEmail">E-MAIL :</label>
                <input type="email" id="cadastroEmail" name="email" required />
            </div>
            <div class="form-group">
                <label for="cadastroSenha">SENHA :</label>
                <input type="password" id="cadastroSenha" name="password" required />
            </div>
            <div class="form-actions">
                <button type="submit">Cadastrar</button>
            </div>
        </form>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $(document).ready(function () {
            // Alterna abas
            $('#loginTab').click(function () {
                $('#cadastroForm').removeClass('active');
                $('#loginForm').addClass('active');
                $('#cadastroTab').removeClass('active');
                $(this).addClass('active');
            });

            $('#cadastroTab').click(function () {
                $('#loginForm').removeClass('active');
                $('#cadastroForm').addClass('active');
                $('#loginTab').removeClass('active');
                $(this).addClass('active');
            });

            // Envio do login
            $('#loginForm').submit(function (e) {
                e.preventDefault();
                var loginData = {
                    Email: $('#loginEmail').val(),
                    Senha: $('#loginSenha').val()
                };

                $.post('/Account/Login', loginData)
                    .done(function () {
                        // window.location.reload();
                         window.location.href = '/Home/Index';
                    })
                    .fail(function () {
                        alert('Erro ao fazer login. Verifique seus dados.');
                    });
            });

            // Envio do cadastro
            $('#cadastroForm').submit(function (e) {
                e.preventDefault();
                var data = {
                    NomeCompleto: $('#cadastroNome').val(),
                    Email: $('#cadastroEmail').val(),
                    Senha: $('#cadastroSenha').val(),
                    ConfirmarSenha: $('#cadastroSenha').val()
                };

                $.post('/Account/Register', data)
                    .done(function () {
                        alert('Cadastro realizado com sucesso!');
                        window.location.href = '/Home/Index';
                    })
                    .fail(function () {
                        alert('Erro ao cadastrar. Verifique os dados.');
                    });
            });
        });
    </script>
</body>
</html>

